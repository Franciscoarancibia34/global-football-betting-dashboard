generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  PRE
  LIVE
  FINAL
}

enum BetStatus {
  OPEN
  WON
  LOST
  VOID
  CASHED_OUT
}

enum AlertType {
  VALUE_BET
  ARBITRAGE
  ODDS_MOVE
  OVER_EXPOSURE
  RESPONSIBLE_GAMING
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  passwordHash    String?
  role            Role            @default(USER)
  bankroll        Decimal         @default(1000) @db.Decimal(12, 2)
  dailyStakeLimit Decimal         @default(100) @db.Decimal(12, 2)
  maxBetStake     Decimal         @default(25) @db.Decimal(12, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  bets            Bet[]
  alerts          Alert[]
  bankrollEvents  BankrollEvent[]
  riskMetrics     RiskMetric[]

  @@map("users")
}

model Bookmaker {
  id        String         @id @default(cuid())
  name      String         @unique
  country   String
  url       String?
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  odds      OddsSnapshot[]
  bets      Bet[]

  @@map("bookmakers")
}

model League {
  id        String   @id @default(cuid())
  name      String
  country   String
  tier      Int      @default(1)
  createdAt DateTime @default(now())
  matches   Match[]
  teams     Team[]

  @@index([country, tier])
  @@map("leagues")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  country   String
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id])
  homeGames Match[]  @relation("homeTeam")
  awayGames Match[]  @relation("awayTeam")
  createdAt DateTime @default(now())

  @@unique([name, leagueId])
  @@map("teams")
}

model Match {
  id          String              @id @default(cuid())
  leagueId    String
  homeTeamId  String
  awayTeamId  String
  kickoffTime DateTime
  status      MatchStatus         @default(PRE)
  minute      Int?
  homeScore   Int                 @default(0)
  awayScore   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  league      League              @relation(fields: [leagueId], references: [id])
  homeTeam    Team                @relation("homeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team                @relation("awayTeam", fields: [awayTeamId], references: [id])
  odds        OddsSnapshot[]
  bets        Bet[]
  modelProbs  ModelProbability[]

  @@index([leagueId, kickoffTime])
  @@index([status, kickoffTime])
  @@map("matches")
}

model Market {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  description String?
  odds        OddsSnapshot[]
  bets        Bet[]
  modelProbs  ModelProbability[]

  @@map("markets")
}

model OddsSnapshot {
  id                  String    @id @default(cuid())
  matchId             String
  marketId            String
  bookmakerId         String
  selection           String
  decimalOdds         Decimal   @db.Decimal(8, 3)
  openingDecimalOdds  Decimal   @db.Decimal(8, 3)
  impliedProbability  Decimal   @db.Decimal(8, 5)
  normalizedProbability Decimal @db.Decimal(8, 5)
  overround           Decimal   @db.Decimal(8, 5)
  timestamp           DateTime  @default(now())
  match               Match     @relation(fields: [matchId], references: [id])
  market              Market    @relation(fields: [marketId], references: [id])
  bookmaker           Bookmaker @relation(fields: [bookmakerId], references: [id])

  @@index([matchId, marketId, bookmakerId, timestamp])
  @@index([timestamp])
  @@map("odds_snapshots")
}

model Bet {
  id            String     @id @default(cuid())
  userId        String
  matchId       String
  marketId      String
  bookmakerId   String
  selection     String
  decimalOdds   Decimal    @db.Decimal(8, 3)
  stake         Decimal    @db.Decimal(12, 2)
  status        BetStatus  @default(OPEN)
  placedAt      DateTime   @default(now())
  settledAt     DateTime?
  profit        Decimal?   @db.Decimal(12, 2)
  closingOdds   Decimal?   @db.Decimal(8, 3)
  strategy      String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id])
  match         Match      @relation(fields: [matchId], references: [id])
  market        Market     @relation(fields: [marketId], references: [id])
  bookmaker     Bookmaker  @relation(fields: [bookmakerId], references: [id])

  @@index([userId, createdAt])
  @@index([matchId, marketId])
  @@map("bets")
}

model BankrollEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  type      String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("bankroll_events")
}

model Alert {
  id        String        @id @default(cuid())
  userId    String?
  type      AlertType
  severity  AlertSeverity @default(INFO)
  title     String
  message   String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime      @default(now())
  user      User?         @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("alerts")
}

model ModelProbability {
  id          String   @id @default(cuid())
  matchId     String
  marketId    String
  selection   String
  probability Decimal  @db.Decimal(8, 5)
  modelName   String
  version     String
  createdAt   DateTime @default(now())
  match       Match    @relation(fields: [matchId], references: [id])
  market      Market   @relation(fields: [marketId], references: [id])

  @@index([matchId, marketId, createdAt])
  @@map("model_probabilities")
}

model RiskMetric {
  id               String   @id @default(cuid())
  userId           String
  exposureTotal    Decimal  @db.Decimal(12, 2)
  exposureByLeague Json
  exposureByMarket Json
  volatility       Decimal  @db.Decimal(8, 5)
  expectedDrawdown Decimal  @db.Decimal(8, 5)
  ruinProbability  Decimal  @db.Decimal(8, 5)
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("risk_metrics")
}
